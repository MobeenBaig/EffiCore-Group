{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "redirects": [
    {
      "source": "https://efficoregroup.com/:path*",
      "destination": "https://www.efficoregroup.com/:path*",
      "permanent": true
    }
  ]
}