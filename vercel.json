{
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "redirects": [
    {
      "source": "https://efficoregroup.com/:path*",
      "destination": "https://www.efficoregroup.com/:path*",
      "permanent": true
    }
  ]
}